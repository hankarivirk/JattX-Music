# ╔══════════════════════════════════════════╗
# ║   JattX Music Bot — Environment Config  ║
# ╚══════════════════════════════════════════╝
# Copy this to .env and fill in your values.

# ── Required ────────────────────────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/JattXMusic
OWNER_ID=123456789
LOGGER_ID=-100987654321      # Channel or group where bot logs are sent

# ── Assistants (at least SESSION is required) ───────────────────────────────
SESSION=your_pyrogram_session_string_here
SESSION2=                    # Optional 2nd assistant for load balancing
SESSION3=                    # Optional 3rd assistant

# ── Support links (auto-generated from bot username if left blank) ──────────
SUPPORT_CHANNEL=https://t.me/YourChannel
SUPPORT_CHAT=https://t.me/YourSupportGroup

# ── Limits ──────────────────────────────────────────────────────────────────
DURATION_LIMIT=90            # Minutes max per track (default 90)
QUEUE_LIMIT=30               # Max tracks in queue
PLAYLIST_LIMIT=25            # Max tracks loaded from a playlist

# ── Autoplay ────────────────────────────────────────────────────────────────
# When queue ends, auto-fetch related songs and keep playing
AUTOPLAY=False
AUTOPLAY_LIMIT=5             # How many related songs to add per refill

# ── Feature flags ───────────────────────────────────────────────────────────
AUTO_LEAVE=False             # Leave VC when queue ends
AUTO_END=True                # Stop call when queue is empty
THUMB_GEN=True               # Generate Now Playing thumbnail cards
VIDEO_PLAY=True              # Allow video streaming

# ── YouTube / yt-dlp ────────────────────────────────────────────────────────
# Space-separated batbin.me cookie URLs (optional but recommended)
COOKIES_URL=
# Extra yt-dlp CLI arguments (e.g. --impersonate chrome)
YT_DLP_EXTRA_ARGS=
# PO token for YouTube bot-detection bypass
YT_PO_TOKEN=
YT_VISITOR_DATA=

# ── Spotify (optional — for Spotify link support) ───────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Localisation ────────────────────────────────────────────────────────────
LANG_CODE=en

# ── Appearance ──────────────────────────────────────────────────────────────
# These MUST be direct image URLs (telegra.ph, catbox.moe, envs.sh, etc.)
# The bot sends them as Telegram photo messages — never as file attachments.
# Replace with your own hosted image URLs.
START_IMG=https://envs.sh/JattX-start.jpg
PING_IMG=https://envs.sh/JattX-ping.jpg
DEFAULT_THUMB=https://envs.sh/JattX-default.jpg
